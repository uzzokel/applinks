

generator client {
  provider = "prisma-client-js"
  // The custom output line has been removed 
}

datasource db {
  provider = "postgresql"
}

// ... your Product model remains exactly the same

model Product {
  id          String   @id @default(cuid())
  userId      String
  productName String
  sku         String?  @unique
  price       Decimal  @db.Decimal(12, 2)
  quantity    Int      @default(0)
  lowStockAt  Int
  imageUrl    String?  // 💡 ADD THIS LINE RIGHT HERE

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, productName])
  @@index([createdAt])
}