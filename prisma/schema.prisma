// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // ⚠️ The 'url' property has been completely removed from here.
  // It is now securely managed inside prisma.config.ts!
}

enum Category {
  General
  Crops
  Livestock
  AgriTech
  Marketplace
}

model Product {
  id          String   @id @default(cuid())
  userId      String
  productName String
  sku         String?  @unique
  price       Decimal  @db.Decimal(12, 2)
  quantity    Int      @default(0)
  lowStockAt  Int
  imageUrl    String?
  description String?  // 👈 Add this line

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, productName])
  @@index([createdAt])
}

model Post {
  id          String    @id @default(uuid())
  authorId    String    // Tied directly to Clerk's user.id
  authorName  String
  authorImage String
  content     String    @db.Text
  category    Category  @default(General)
  tags        String[]  // Native PostgreSQL string arrays
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  comments    Comment[]
  likes       Like[]

  @@index([authorId])
  @@index([category])
}

model Comment {
  id          String   @id @default(uuid())
  postId      String
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorName  String
  authorImage String
  content     String   @db.Text
  createdAt   DateTime @default(now())

  @@index([postId])
}

model Like {
  id     String @id @default(uuid())
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String // Clerk user ID who liked it
  
  @@unique([postId, userId]) // Prevents duplicate likes from a single user
}

